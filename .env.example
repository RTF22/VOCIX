ANTHROPIC_API_KEY=sk-ant-your-key-here

# Language — controls UI, Claude prompts and Whisper STT.
# Allowed values: de, en. Default: de. Can be toggled at runtime in the tray menu.
# The tray selection (stored in state.json) overrides this value.
# VOCIX_LANGUAGE=de

# Override for Whisper STT language (rarely needed — follows VOCIX_LANGUAGE by default).
# VOCIX_WHISPER_LANGUAGE=

# Hotkeys — Push-to-Talk (hold = record, release = process)
# Default: pause (no standard Windows / browser / Office / IDE binding — safe everywhere).
# Laptop without a dedicated Pause key? Try `scroll lock` or `f7` instead.
#
# Single keys:    pause, scroll lock, f7, f8, f6, f5, print screen
# Combinations:   ctrl+shift+space, alt+shift+r, ctrl+alt+d
#
# VOCIX_HOTKEY_RECORD=pause
# VOCIX_HOTKEY_MODE_A=ctrl+shift+1
# VOCIX_HOTKEY_MODE_B=ctrl+shift+2
# VOCIX_HOTKEY_MODE_C=ctrl+shift+3

# Logging (DEBUG, INFO, WARNING, ERROR)
# VOCIX_LOG_LEVEL=INFO
# VOCIX_LOG_FILE=vocix.log

# RDP mode: longer clipboard delays for Remote Desktop sessions
# VOCIX_RDP_MODE=true
