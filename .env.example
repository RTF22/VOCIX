ANTHROPIC_API_KEY=sk-ant-your-key-here

# Hotkeys — Push-to-Talk (halten = aufnehmen, loslassen = verarbeiten)
# Standard: F9
#
# Einzeltasten:       f9, f8, f7, f6, f5, pause, scroll lock, print screen
# Kombinationen:      ctrl+shift+space, alt+shift+r, ctrl+alt+d
#
# VOCIX_HOTKEY_RECORD=f9
# VOCIX_HOTKEY_MODE_A=ctrl+shift+1
# VOCIX_HOTKEY_MODE_B=ctrl+shift+2
# VOCIX_HOTKEY_MODE_C=ctrl+shift+3

# Logging (DEBUG, INFO, WARNING, ERROR)
# VOCIX_LOG_LEVEL=INFO
# VOCIX_LOG_FILE=vocix.log

# RDP-Modus: Längere Clipboard-Delays für Remote-Desktop-Sessions
# VOCIX_RDP_MODE=true
